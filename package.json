{
  "name": "mcp-skeleton",
  "version": "0.1.0",
  "description": "A minimal, reusable toolkit for bootstrapping Model Context Protocol (MCP) servers in TypeScript.",
  "type": "module",
  "bin": {
    "mcp-skeleton": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "inspect": "npx @modelcontextprotocol/inspector tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "skeleton",
    "toolkit"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
